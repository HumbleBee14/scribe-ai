.env
.env.local

# SQLite WAL/SHM files (runtime only, not the db itself)
data/local.db-wal
data/local.db-shm

# User-created products (evaluator only gets seeded products via git)
data/products/*/jobs/
data/products/*/conversations/

# Python / Node local artifacts
backend/.venv/
backend/__pycache__/
backend/.pytest_cache/
backend/.ruff_cache/
frontend/node_modules/
frontend/.next/
